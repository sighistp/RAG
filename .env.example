# RAGv3 环境变量配置
# 复制本文件为 .env 并填入你的 API Key
#
# cp .env.example .env

# DeepSeek 生成模型
RAG_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
RAG_DEEPSEEK_BASE_URL=https://api.deepseek.com
RAG_DEEPSEEK_MODEL=deepseek-v4-flash

# 硅基流动 嵌入模型（bge-m3，免费额度）
RAG_BAILIAN_API_KEY=sk-xxxxxxxxxxxxxxxx
# RAG_BAILIAN_BASE_URL=https://api.siliconflow.cn/v1
# RAG_BAILIAN_EMBED_MODEL=BAAI/bge-m3

# 百炼 Rerank（如果 reranker 也欠费，可注释掉，系统会跳过重排序）
# RAG_BAILIAN_API_KEY=sk-xxxxxxxxxxxxxxxx
# RAG_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RAG_BAILIAN_RERANK_MODEL=gte-rerank-v2

# 鉴权（可选，默认关闭）
# RAG_AUTH_ENABLED=false
# RAG_AUTH_KEYS={"your-api-key": "user1"}

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# RAG_LOG_LEVEL=INFO

# 生产环境 JSON 格式日志
# RAG_LOG_JSON=0

# 首次部署时指定初始管理员用户名（可选）
# INIT_ADMIN_USERNAME=admin
