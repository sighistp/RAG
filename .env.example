# RAGv3 环境变量配置
# 复制本文件为 .env 并填入你的 API Key
#
# cp .env.example .env

# DeepSeek 生成模型
RAG_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
RAG_DEEPSEEK_BASE_URL=https://api.deepseek.com
RAG_DEEPSEEK_MODEL=deepseek-v4-flash

# 百炼（阿里云 DashScope）嵌入 + 重排序
RAG_BAILIAN_API_KEY=sk-xxxxxxxxxxxxxxxx
RAG_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 鉴权（可选，默认关闭）
# RAG_AUTH_ENABLED=false
# RAG_AUTH_KEYS={"your-api-key": "user1"}

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# RAG_LOG_LEVEL=INFO

# 生产环境 JSON 格式日志
# RAG_LOG_JSON=0
